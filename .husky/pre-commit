#!/usr/bin/env sh
set -e

echo "🔍 lint-staged (ESLint/Prettier staged UI, gofmt staged API)..."
npx lint-staged

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if echo "$STAGED_FILES" | grep -qE '^apps/web/'; then
  echo "📦 UI: typecheck + full ESLint..."
  npm --prefix apps/web run typecheck
  npm --prefix apps/web run lint
fi

if echo "$STAGED_FILES" | grep -qE '^apps/api/.*\.go$|^apps/api/go\.(mod|sum)$'; then
  echo "🔧 API: go vet + go test..."
  (cd apps/api && go vet ./... && go test ./...)
fi

echo "✅ pre-commit OK"
